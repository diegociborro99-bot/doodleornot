{
  "name": "doodle-or-not",
  "version": "2.0.0",
  "private": true,
  "description": "Daily Doodles NFT trivia game — PostgreSQL-backed.",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "postinstall": "prisma generate && npx tailwindcss -i tw-input.css -o public/tailwind.css --minify",
